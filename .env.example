# Database
POSTGRES_USER=communitypulse
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=communitypulse

# Valkey/Redis
VALKEY_PASSWORD=change_me_in_production

# Application
SECRET_KEY=generate_with_openssl_rand_base64_32
DEBUG=true

# YouTube API
# Get API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
# Comma-separated channel IDs (find via: https://www.youtube.com/account_advanced)
YOUTUBE_CHANNEL_IDS=
# Comma-separated search queries for discovery (uses more quota)
YOUTUBE_SEARCH_QUERIES=
# Max videos per channel (default 50)
YOUTUBE_FETCH_LIMIT=50
# Daily quota limit (free tier is 10,000 units)
YOUTUBE_DAILY_QUOTA_LIMIT=9000
